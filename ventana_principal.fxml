<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<VBox spacing="20.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="_Bibliotecapp.controlador.MainController">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- CABECERA -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #2c3e50; -fx-padding: 15; -fx-background-radius: 10;">
        <effect>
            <DropShadow blurType="GAUSSIAN" height="10.0" radius="4.5" width="10.0">
                <color><Color opacity="0.3" /></color>
            </DropShadow>
        </effect>
        <children>
            <VBox>
                <children>
                    <Label text="BIBLIOTECAPP" textFill="WHITE">
                        <font><Font name="System Bold" size="26.0" /></font>
                    </Label>
                    <Label text="La gestión de tu biblioteca" textFill="#bdc3c7" />
                </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtBusqueda" prefHeight="35.0" prefWidth="300.0" promptText="🔍 Buscar por título, autor o REF..." style="-fx-background-radius: 20;" />
        </children>
    </HBox>

    <!-- FORMULARIO DE ENTRADA -->
    <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #dcdde1;">
        <children>
            <TextField fx:id="txtReferencia" prefWidth="80.0" promptText="REF" />
            <TextField fx:id="txtTitulo" promptText="Título del libro" HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtAutor" promptText="Autor" HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtIsbn" prefWidth="110.0" promptText="ISBN (Opcional)" />
            <Button onAction="#handleInsertar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="＋ AÑADIR" />
            <Separator orientation="VERTICAL" />
            <Button onAction="#handleImportarExcel" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="📥 EXCEL" />
        </children>
    </HBox>

    <!-- TABLA -->
  <TableView fx:id="tablaLibros" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
        <columns>
            <TableColumn fx:id="colReferencia" prefWidth="70.0" text="REF" />
            <TableColumn fx:id="colTitulo" prefWidth="180.0" text="TÍTULO" />
            <TableColumn fx:id="colAutor" prefWidth="130.0" text="AUTOR" />
            <TableColumn fx:id="colIsbn" prefWidth="100.0" text="ISBN" /> <TableColumn fx:id="colPrestado" prefWidth="75.0" text="PRESTADO" />
            <TableColumn fx:id="colUsuario" prefWidth="110.0" text="POSEEDOR" />
            <TableColumn fx:id="colTelefono" prefWidth="100.0" text="TELÉFONO" />
            <TableColumn fx:id="colFecha" prefWidth="100.0" text="FECHA" />
            <TableColumn fx:id="colVeces" prefWidth="50.0" text="USOS" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- BARRA INFERIOR -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #34495e; -fx-padding: 12; -fx-background-radius: 8;">
        <children>
            <Label fx:id="lblTotalLibros" text="Libros: 0" textFill="WHITE" style="-fx-font-weight: bold;" />
            <Label fx:id="lblLibrosPrestados" text="Prestados: 0" textFill="#f1c40f" style="-fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleCambiarEstado" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;" text="🔄 PRESTAR / DEVOLVER" />
            <Button onAction="#handleEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="🗑 BORRAR" />
            <Button onAction="#handleCargar" text="↻" />
        </children>
    </HBox>

</VBox>